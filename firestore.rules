rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function hasProfile(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function hasActiveProfile() {
      return signedIn()
        && hasProfile(request.auth.uid)
        && userProfile(request.auth.uid).data.status == 'active';
    }

    function isAdmin() {
      return hasActiveProfile() && userProfile(request.auth.uid).data.role == 'Admin';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // STAGING BOOTSTRAP:
    // Any signed-in user may create their own user profile once.
    // This lets the first user click "Bootstrap me as Admin" from the app.
    // Tighten before production.
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid) && !hasProfile(uid);
      allow update: if isSelf(uid) || isAdmin();
      allow delete: if false;
    }

    match /emailAllowlist/{emailId} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (signedIn()
          && request.auth.token.email == 'noobsnoobs28@gmail.com'
          && emailId == 'noobsnoobs28_gmail_com'
          && request.resource.data.email == 'noobsnoobs28@gmail.com');
      allow update, delete: if isAdmin();
    }

    match /userInvites/{inviteId} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (signedIn()
          && request.auth.token.email == 'noobsnoobs28@gmail.com'
          && inviteId == 'noobsnoobs28_gmail_com'
          && request.resource.data.email == 'noobsnoobs28@gmail.com');
      allow update, delete: if isAdmin();
    }

    // STAGING APP DATA:
    // Active signed-in app users can read/write app data.
    // This keeps staging easy while still requiring login + active profile.
    match /categories/{categoryId} {
      allow read, write: if hasActiveProfile();
    }

    match /priceItems/{itemId} {
      allow read, write: if hasActiveProfile();
    }

    match /priceAuditEntries/{entryId} {
      allow read, create: if hasActiveProfile();
      allow update, delete: if false;
    }

    match /quotes/{quoteId} {
      // All active users can read and create estimates
      allow read, create: if hasActiveProfile();

      // Authenticated users can delete any estimate in staging
      // In production, restrict to owner or admin only
      allow update, delete: if signedIn();
    }

    match /vendorEstimates/{vendorEstimateId} {
      // All active users can read and create vendor estimates
      allow read, create: if hasActiveProfile();

      // Authenticated users can update/delete any vendor estimate in staging
      // In production, restrict to owner or admin only
      allow update, delete: if signedIn();
    }

    match /paperCalculatorDrafts/{uid} {
      allow read, delete: if hasActiveProfile() && request.auth.uid == uid;
      allow create, update: if hasActiveProfile()
        && request.auth.uid == uid
        && request.resource.data.userId == uid
        && request.resource.data.schemaVersion == 1;
    }

    match /paperCalculations/{calculationId} {
      allow read: if hasActiveProfile();
      allow create: if hasActiveProfile()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.schemaVersion == 1
        && request.resource.data.module in ['layout', 'book', 'plano', 'time'];
      allow update: if false;
      allow delete: if hasActiveProfile()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /paperCustomSizes/{sizeId} {
      allow read: if hasActiveProfile();
      allow create: if hasActiveProfile()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.schemaVersion == 1
        && request.resource.data.type in ['paper', 'book', 'plano']
        && request.resource.data.width is number
        && request.resource.data.width > 0
        && request.resource.data.height is number
        && request.resource.data.height > 0;
      allow update: if hasActiveProfile()
        && (resource.data.createdBy == request.auth.uid || isAdmin())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.schemaVersion == 1
        && request.resource.data.type in ['paper', 'book', 'plano']
        && request.resource.data.width is number
        && request.resource.data.width > 0
        && request.resource.data.height is number
        && request.resource.data.height > 0;
      allow delete: if hasActiveProfile()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }
  }
}
